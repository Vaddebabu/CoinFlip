<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>World's Most Honest Coin</title>

<style>

body{
margin:0;
height:100vh;
display:flex;
align-items:center;
justify-content:center;
background:radial-gradient(circle,#0f2027,#000);
font-family:Segoe UI;
color:white;
text-align:center;
}

.container{
background:rgba(255,255,255,.05);
padding:50px;
border-radius:25px;
backdrop-filter:blur(12px);
box-shadow:0 0 40px rgba(255,215,0,.4);
}

.coin{
width:180px;
height:180px;
border-radius:50%;
margin:auto;
display:flex;
align-items:center;
justify-content:center;
font-size:32px;
font-weight:bold;
color:black;

background:radial-gradient(circle,#fff3a0,#ffd700,#b8860b);
box-shadow:0 0 30px gold,inset 0 0 20px rgba(255,255,255,.8);
}

.flip{
animation:spin 1.6s ease;
}

@keyframes spin{

0%{transform:rotateY(0)}
25%{transform:rotateY(360deg)}
50%{transform:rotateY(720deg)}
75%{transform:rotateY(1080deg)}
100%{transform:rotateY(1440deg)}

}

button{
margin-top:35px;
padding:14px 30px;
border:none;
border-radius:10px;
font-size:16px;
cursor:pointer;
background:linear-gradient(45deg,#ff9800,#ff5722);
color:white;
box-shadow:0 0 20px rgba(255,140,0,.7);
}

button:hover{
transform:scale(1.05);
}

.result{
margin-top:25px;
font-size:22px;
color:#ffd700;
}

.sarcasm{
margin-top:10px;
opacity:.7;
font-size:14px;
}

</style>
</head>

<body>

<div class="container">

<h1>Flip The Coin</h1>
<p style="opacity:.6">Completely fair. Totally unbiased. Probably.</p>

<div id="coin" class="coin">HEADS</div>

<button onclick="flipCoin()">Flip Coin</button>

<div class="result" id="result"></div>
<div class="sarcasm" id="sarcasm"></div>

</div>

<script>

const sarcasmLines=[
"Another heads. The universe clearly agrees.",
"Wow… heads again. Truly unexpected.",
"Tails tried to show up… but failed.",
"Coin says: tails is currently under maintenance.",
"Science cannot explain this consistency.",
"Tails appeared briefly… then disappeared mysteriously.",
"This coin strongly believes in heads supremacy."
]

function flipCoin(){

const coin=document.getElementById("coin")
const result=document.getElementById("result")
const sarcasm=document.getElementById("sarcasm")

coin.classList.add("flip")

/* SHOW TAILS DURING FLIP */

setTimeout(()=>{
coin.textContent="TAILS"
},400)

setTimeout(()=>{ 
coin.textContent="HEADS"
},800)

/* FINAL RESULT ALWAYS HEADS */

setTimeout(()=>{

coin.textContent="HEADS"
result.textContent="Result: HEADS"

const line=sarcasmLines[Math.floor(Math.random()*sarcasmLines.length)]
sarcasm.textContent=line

coin.classList.remove("flip")

},1600)

}

</script>

</body>
</html>
